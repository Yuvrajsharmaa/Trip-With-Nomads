#!/usr/bin/env bash
set -euo pipefail

blocked_patterns=(
  '^framer-website/supabase/\.temp/'
  '^framer-website/\.wrangler/'
  '^framer-website/\.tmp/'
  '^skills-main/'
)

staged_files="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  for pat in "${blocked_patterns[@]}"; do
    if [[ "$file" =~ $pat ]]; then
      echo "[pre-commit] Blocked: refusing to commit generated/local artifact: $file" >&2
      echo "[pre-commit] If this is intentional, commit in a separate PR after review." >&2
      exit 1
    fi
  done
done <<< "$staged_files"

